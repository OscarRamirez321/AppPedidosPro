<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Dónde te entregamos?"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/etCalle"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Barrio o Residencial"
        android:background="#F5F5F5"
        android:padding="15dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/etReferencia"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Punto de referencia (Ej: Frente a la pulpería...)"
        android:gravity="top"
        android:background="#F5F5F5"
        android:padding="15dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnGuardarDir"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="GUARDAR DIRECCIÓN"
        android:textColor="#FFFFFF"
        android:backgroundTint="#000000" />
</LinearLayout>